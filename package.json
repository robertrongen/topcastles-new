{
  "name": "topcastles",
  "version": "0.0.0",
  "private": true,
  "description": "Angular 19 castle-ranking website with SSR, Storybook, and Docker deployment",
  "scripts": {
    "install:all": "npm install --prefix new_app && npm install --prefix scripts && npm install --prefix server",

    "start": "npm start --prefix new_app",
    "dev:server": "node server/index.js",
    "dev:app": "npm start --prefix new_app",
    "build": "npm run build --prefix new_app",
    "build:watch": "npm run watch --prefix new_app",
    "test": "npx --prefix new_app ng test --watch=false --browsers=ChromeHeadless",

    "storybook": "npm run storybook --prefix new_app",
    "build:storybook": "npm run build-storybook --prefix new_app",

    "data:convert": "python scripts/xlsx_to_json.py",
    "data:enrich:wikidata": "node scripts/enrich_wikidata.js",
    "data:enrich:wikipedia": "node scripts/enrich_wikipedia.js",
    "data:api": "node scripts/generate_api.js",
    "data:lean": "node scripts/generate_lean_castles.js",
    "data:sitemap": "node scripts/generate_sitemap.js",
    "data:routes": "node scripts/generate_prerender_routes.js",
    "mcp": "node scripts/mcp-server.js",

    "graph:build": "graphify build .",
    "graph:update": "graphify auto-update .",
    "graph:query": "graphify query graphify-out/graph.json",

    "deploy": "bash deploy.sh"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}
