{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "[ -f graphify-out/graph.json ] \u0026\u0026 echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify-ts: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true",
            "type": "command"
          }
        ],
        "matcher": "Glob|Grep"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git commit -m ' *)",
      "Bash(python3 -c ' *)",
      "Bash(node -e ' *)",
      "Bash(node_modules/.bin/ng build *)",
      "Bash(new_app/node_modules/.bin/ng build *)"
    ]
  }
}