{
  "permissions": {
    "allow": [
      "Bash(node -e ' *)",
      "Bash(node_modules/.bin/ng build *)",
      "Bash(new_app/node_modules/.bin/ng build *)",
      "Bash(node scripts/*",
      "Bash(git *)",
      "Bash(node scripts/enrich_wikipedia.js *)",
      "Bash(python3 *",
      "Bash(bd *)",
      "Bash(git -C c:/github/topcastles *)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists at graphify-out/graph.json. Use `graphify query graphify-out/graph.json <name>` to look up symbols instead of searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ]
  }
}
